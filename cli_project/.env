CLAUDE_MODEL="claude-sonnet-4-5"
ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY"

# Set to 1 if you're using uv to run the project
# Set to 0 if you're *not* using uv
USE_UV=1


{
  "method": "notifications/message",
  "params": {
    "level": "info",
    "logger": "stdio",
    "data": {
      "message": ") depends on\n        `mcp` (v1.21.0) which depends on `pyjwt[crypto]` (v2.10.1) which\n        depends on `cryptography` (v46.0.3) which depends on `cffi` (v2.0.0)\n        which depends on `pycparser`"
    }
  }
}